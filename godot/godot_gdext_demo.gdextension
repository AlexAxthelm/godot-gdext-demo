[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
; Paths are relative to the Godot project root (res://).
; The library sits one directory up in rust/target/.

linux.debug.x86_64   = "res://../rust/target/debug/libgodot_gdext_demo.so"
linux.release.x86_64 = "res://../rust/target/release/libgodot_gdext_demo.so"

macos.debug          = "res://../rust/target/debug/libgodot_gdext_demo.dylib"
macos.release        = "res://../rust/target/release/libgodot_gdext_demo.dylib"

windows.debug.x86_64   = "res://../rust/target/debug/godot_gdext_demo.dll"
windows.release.x86_64 = "res://../rust/target/release/godot_gdext_demo.dll"

; Wasm — no-threads build (works on all hosts, no SharedArrayBuffer required)
web.debug.wasm32   = "res://../rust/target/wasm32-unknown-emscripten/debug/godot_gdext_demo.wasm"
web.release.wasm32 = "res://../rust/target/wasm32-unknown-emscripten/release/godot_gdext_demo.wasm"

; iOS — static library (arm64 device for both debug and release)
; For local testing: open the exported .xcodeproj in Xcode, pick "My Mac (Designed for iPad)" as the destination.
; That runs the arm64 device binary directly on macOS via Apple's compatibility layer — no dev account needed.
; For on-device testing: requires a paid Apple Developer account for signing.
ios.debug   = "res://../rust/target/aarch64-apple-ios/debug/libgodot_gdext_demo.a"
ios.release = "res://../rust/target/aarch64-apple-ios/release/libgodot_gdext_demo.a"
